# ============================================================
# .env.example — Quizoi Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── Supabase Database ────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → Database → Connection String
# Use the "Session Pooler" URL (port 6543) — required for serverless/Railway.
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:6543/postgres

# ─── Supabase API Keys ────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
# ANON key: safe to expose to the browser (used for public read operations)
# SERVICE ROLE key: NEVER expose to the browser — server-side only
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Admin Authentication ─────────────────────────────────────────────────────
# Secret header value required for all /api/admin/* routes.
# Generate a strong random string: openssl rand -base64 32
ADMIN_SECRET=change-this-to-a-strong-random-secret

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Google AdSense (optional — add when applying for AdSense) ───────────────
# ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX
